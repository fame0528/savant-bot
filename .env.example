# savant-bot environment configuration — TEMPLATE
#
# Copy this file to .env and fill in real values. The .env file is gitignored.
# DO NOT commit real secrets. DO NOT paste the .env contents anywhere public.
# This .env.example file IS safe to commit.

# === Discord ===
# Required. Create a Discord application at https://discord.com/developers/applications
# Then add a Bot to the application and copy the token here.
# Regenerate the token in the developer portal if it ever appears in plaintext
# (chat logs, screenshots, commits) — treat as compromised.
DISCORD_BOT_TOKEN=

# === Database ===
# Required. Path to the SQLite database file. Relative paths are resolved from the
# working directory at process start. The directory must exist and be writable.
# For a single-host bot, SQLite is sufficient. If we ever shard, swap to PostgreSQL
# and use a postgres:// URL instead.
DATABASE_URL=sqlite:savant-bot.db

# === LLM (OpenRouter) ===
# Required for LLM features. Get an API key at https://openrouter.ai/keys
# OpenRouter is the primary provider; it provides native failover to alternative
# models via the `models: []` payload array (see doc §3.2 line 104).
OPENROUTER_API_KEY=

# === LLM Defaults ===
# Optional. The default model to use when no override is specified.
# Examples: openrouter/auto, anthropic/claude-3.5-sonnet, openai/gpt-4o-mini
# Free tier: openrouter/auto (auto-routes to free models with rate limits)
LLM_DEFAULT_MODEL=openrouter/auto

# === Logging ===
# Optional. tracing-subscriber env-filter format.
# Examples: info, savant_bot=debug, savant_bot::llm=trace
RUST_LOG=info,savant_bot=debug

# === Bot Identity ===
# Optional. The bot's display name (used in /help and embeds). Defaults to "savant-bot".
BOT_DISPLAY_NAME=savant-bot

# Optional. Command prefix for legacy text commands. Poise supports both slash and
# text commands. Set to empty string to disable text commands entirely.
COMMAND_PREFIX=!

# === Rate Limiting (LLM) ===
# Optional. Token-bucket rate per user for LLM calls.
# Format: <max_tokens>:<refill_per_second>
# Defaults: 5:0.5 (5 requests, refilling 0.5 per second = 30/min)
LLM_RATE_LIMIT=5:0.5
